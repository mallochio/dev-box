{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "azure": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Azure AI Foundry",
      "options": {
        "baseURL": "http://127.0.0.1:41437/v1",
        "apiKey": "proxy"
      },
      "models": {
        "model-router": {
          "name": "Model Router (Azure Foundry)",
          "limit": {
            "context": 400000,
            "output": 128000
          }
        },
        "gpt-5.6-terra": {
          "name": "GPT 5.6 Terra",
          "limit": {
            "context": 1050000,
            "output": 128000
          }
        },
        "gpt-5.6-luna": {
          "name": "GPT 5.6 Luna",
          "limit": {
            "context": 1050000,
            "output": 128000
          }
        },
        "deepseek-v4-flash-max": {
          "name": "DeepSeek V4 Flash Max (Azure)",
          "limit": {
            "context": 1000000,
            "output": 128000
          }
        },
        "deepseek-v4-flash": {
          "name": "DeepSeek V4 Flash (Azure)",
          "limit": {
            "context": 1000000,
            "output": 128000
          }
        },
        "kimi-k2.7-code": {
          "name": "Kimi K2.7 Code (Azure)",
          "limit": {
            "context": 262144,
            "output": 262144
          }
        }
      }
    }
  },
  "model": "azure/kimi-k2.7-code",
  "small_model": "azure/gpt-5.6-luna"
}
